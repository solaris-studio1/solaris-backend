# ─── SERVER ───────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── JWT ──────────────────────────────────────────
# Cambia esto por una clave secreta larga y aleatoria
JWT_SECRET=solaris_super_secret_key_cambiar_en_produccion_2026
JWT_EXPIRES_IN=7d

# ─── DATABASE ─────────────────────────────────────
# SQLite (archivo local, perfecto para empezar)
DB_PATH=./solaris.db

# ─── STRIPE (tarjeta + Apple Pay + Google Pay) ────
# Obtén estas claves en https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_TU_CLAVE_SECRETA_AQUI
STRIPE_PUBLISHABLE_KEY=pk_test_TU_CLAVE_PUBLICA_AQUI
STRIPE_WEBHOOK_SECRET=whsec_TU_WEBHOOK_SECRET_AQUI

# ─── CASHAPP (Square) ─────────────────────────────
# Obtén estas claves en https://developer.squareup.com
SQUARE_ACCESS_TOKEN=TU_SQUARE_ACCESS_TOKEN
SQUARE_LOCATION_ID=TU_LOCATION_ID
SQUARE_ENVIRONMENT=sandbox   # cambiar a "production" cuando estés listo

# ─── CRYPTO (Coinbase Commerce) ───────────────────
# Obtén la API key en https://commerce.coinbase.com/settings/security
COINBASE_COMMERCE_API_KEY=TU_COINBASE_API_KEY
COINBASE_WEBHOOK_SECRET=TU_COINBASE_WEBHOOK_SECRET

# ─── FRONTEND URL (CORS) ──────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── CASHAPP MANUAL ───────────────────────────────
# Tu CashTag personal donde recibes pagos
CASHAPP_CASHTAG=$SolarisEntertainment
